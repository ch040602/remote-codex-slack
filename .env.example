# Slack Bot token. Required.
SLACK_BOT_TOKEN=xoxb-...

# Slack App-level token with connections:write. Required for Socket Mode.
SLACK_APP_TOKEN=xapp-...

# Optional when using Socket Mode. Required for HTTP mode if you add it later.
SLACK_SIGNING_SECRET=

# Comma-separated Slack user IDs allowed to operate the bridge.
# Empty means deny all, unless ALLOW_ALL_SLACK_USERS=1 is set.
ALLOWED_SLACK_USER_IDS=U0123456789,U9876543210
ALLOW_ALL_SLACK_USERS=0

# Message command prefix for normal channel/thread messages.
# Slash command is still /codex.
SLACK_COMMAND_PREFIX=!codex

# Root folder for Slack-driven channel creation and cd/ls exploration.
CODEX_NAV_ROOT=%USERPROFILE%/Desktop

# Local Codex executable. Use codex.cmd on Windows only if codex is not in PATH.
CODEX_DRIVER=cli
CODEX_BIN=codex
CODEX_SESSIONS_DIR=%USERPROFILE%/.codex/sessions

# Codex defaults.
CODEX_MODEL=
CODEX_SANDBOX=workspaceWrite
CODEX_APPROVAL_POLICY=never
CODEX_REASONING_EFFORT=

# JSON state file.
STATE_PATH=./data/state.json

# YAML configs.
PROJECTS_CONFIG=./config/projects.yaml
SKILLS_CONFIG=./config/skills.yaml

# Limit Slack message chunks.
SLACK_MAX_MESSAGE_CHARS=3500

# Strict $skill handling. 1 = unknown $tokens fail prompt, 0 = leave unknown $tokens as plain text.
STRICT_SKILL_REFERENCES=1

# Optional channel bootstrap.
# Required only for npm run channels:create.
DEFAULT_INVITE_USER_IDS=U0123456789
CREATE_PRIVATE_CHANNELS=0
